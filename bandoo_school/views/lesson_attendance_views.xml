<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="bandoo_lesson_attendance_view_pivot" model="ir.ui.view">
        <field name="name">bandoo.lesson.attendance.pivot</field>
        <field name="model">bandoo.lesson.attendance</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="billing_status" type="row"/>
                <field name="partner_id" type="row"/>
                <field name="project_id" type="row"/>
                <field name="date" type="col" interval="month"/>
                <field name="task_id" type="measure" string="Lezioni"/>
            </pivot>
        </field>
    </record>

    <record id="bandoo_lesson_attendance_view_list" model="ir.ui.view">
        <field name="name">bandoo.lesson.attendance.list</field>
        <field name="model">bandoo.lesson.attendance</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="project_id"/>
                <field name="partner_id"/>
                <field name="task_id"/>
                <field name="billing_status" widget="badge"
                       decoration-success="billing_status == 'pays'"
                       decoration-warning="billing_status == 'free'"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'present'"
                       decoration-danger="status == 'absent'"
                       decoration-warning="status == 'absent_justified'"/>
            </list>
        </field>
    </record>

    <record id="bandoo_lesson_attendance_view_search" model="ir.ui.view">
        <field name="name">bandoo.lesson.attendance.search</field>
        <field name="model">bandoo.lesson.attendance</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="project_id"/>
                <filter name="present" string="Presente"
                        domain="[('status', '=', 'present')]"/>
                <filter name="absent" string="Assente"
                        domain="[('status', '=', 'absent')]"/>
                <filter name="absent_justified" string="Assente giustificato"
                        domain="[('status', '=', 'absent_justified')]"/>
                <group expand="0" string="Raggruppa per">
                    <filter name="group_billing" string="Ai fini retta"
                            context="{'group_by': 'billing_status'}"/>
                    <filter name="group_project" string="Corso"
                            context="{'group_by': 'project_id'}"/>
                    <filter name="group_partner" string="Studente"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_status" string="Stato"
                            context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="bandoo_lesson_attendance_action" model="ir.actions.act_window">
        <field name="name">Presenze studenti</field>
        <field name="res_model">bandoo.lesson.attendance</field>
        <field name="view_mode">pivot,list</field>
        <field name="context">{'search_default_group_billing': 1}</field>
    </record>

    <menuitem
        id="menu_bandoo_lesson_attendance"
        name="Presenze studenti"
        parent="project.menu_project_report"
        action="bandoo_lesson_attendance_action"
        sequence="20"/>

</odoo>
