<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_order_form_bandoo_sale" model="ir.ui.view">
        <field name="name">sale.order.form.bandoo.sale</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list//field[@name='product_id']"
                   position="before">
                <field name="x_student_id"
                       options="{'no_create': True}"
                       optional="show"/>
                <field name="x_project_id"
                       options="{'no_create': True}"
                       optional="show"/>
                <field name="x_lesson_target" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
