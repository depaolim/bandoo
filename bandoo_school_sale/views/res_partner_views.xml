<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_bandoo_sale" model="ir.ui.view">
        <field name="name">res.partner.form.bandoo.sale</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <field name="category_id" position="after">
                <field name="x_is_member"/>
                <field name="x_guardian_id"
                       invisible="not x_is_student"
                       domain="[('id', '!=', id)]"/>
            </field>
        </field>
    </record>

</odoo>
