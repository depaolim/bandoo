<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="bandoo_enrollment_settlement_view_list" model="ir.ui.view">
        <field name="name">bandoo.enrollment.settlement.list</field>
        <field name="model">bandoo.enrollment.settlement</field>
        <field name="arch" type="xml">
            <list create="false" edit="false">
                <field name="partner_id"/>
                <field name="project_id"/>
                <field name="payer_id" optional="show"/>
                <field name="annual_price" sum="Totale"/>
                <field name="target"/>
                <field name="lessons_held"/>
                <field name="missed_lessons"/>
                <field name="justified_absences"/>
                <field name="price_per_lesson"/>
                <field name="deduction" sum="Totale"/>
                <field name="installment_1" sum="Totale"/>
                <field name="installment_2" sum="Totale"/>
                <field name="installment_3" sum="Totale"/>
            </list>
        </field>
    </record>

    <record id="bandoo_enrollment_settlement_view_form" model="ir.ui.view">
        <field name="name">bandoo.enrollment.settlement.form</field>
        <field name="model">bandoo.enrollment.settlement</field>
        <field name="arch" type="xml">
            <form create="false" edit="false">
                <sheet>
                    <group>
                        <group string="Iscrizione">
                            <field name="partner_id"/>
                            <field name="project_id"/>
                            <field name="payer_id"/>
                            <field name="order_id"/>
                            <field name="annual_price"/>
                        </group>
                        <group string="Conguaglio">
                            <field name="target"/>
                            <field name="lessons_held"/>
                            <field name="missed_lessons"/>
                            <field name="justified_absences"/>
                            <field name="price_per_lesson"/>
                            <field name="deduction"/>
                        </group>
                    </group>
                    <group string="Rate">
                        <field name="installment_1"/>
                        <field name="installment_2"/>
                        <field name="installment_3"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="bandoo_enrollment_settlement_view_search" model="ir.ui.view">
        <field name="name">bandoo.enrollment.settlement.search</field>
        <field name="model">bandoo.enrollment.settlement</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="project_id"/>
                <field name="payer_id"/>
                <group expand="0" string="Raggruppa per">
                    <filter name="group_project" string="Corso"
                            context="{'group_by': 'project_id'}"/>
                    <filter name="group_payer" string="Pagatore"
                            context="{'group_by': 'payer_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="bandoo_enrollment_settlement_action" model="ir.actions.act_window">
        <field name="name">Conguagli iscrizioni</field>
        <field name="res_model">bandoo.enrollment.settlement</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_bandoo_enrollment_settlement"
        name="Conguagli iscrizioni"
        parent="sale.sale_order_menu"
        action="bandoo_enrollment_settlement_action"
        sequence="50"/>

</odoo>
