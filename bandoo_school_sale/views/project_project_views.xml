<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_project_form_bandoo_sale" model="ir.ui.view">
        <field name="name">project.project.form.bandoo.sale</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <field name="user_id" position="after">
                <field name="x_is_course"/>
                <field name="x_is_solfeggio" invisible="not x_is_course"/>
                <field name="x_list_price" invisible="not x_is_course"/>
                <field name="x_lesson_target" invisible="not x_is_course"/>
            </field>
        </field>
    </record>

</odoo>
