<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_bandoo_sale" model="ir.ui.view">
        <field name="name">product.template.form.bandoo.sale</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="sale.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']" position="inside">
                <group name="bandoo_course" string="Corso">
                    <field name="x_course_project_id"
                           invisible="service_tracking != 'course_collective'"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
