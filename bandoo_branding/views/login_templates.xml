<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="login_layout" inherit_id="web.login_layout">
        <xpath expr="//img[contains(@t-attf-src, 'company_logo')]" position="replace">
            <img src="/bandoo_branding/static/img/logo.png"
                 alt="Bandoo"
                 style="max-height:120px; max-width: 100%; width:auto"/>
        </xpath>
    </template>
</odoo>
